{
  "testId": "wheel-of-names",
  "name": "Wheel of Names",
  "version": "1.0.1",
  "manifestVersion": 2,
  "requirements": {
    "apps": [
      {
        "name": "Express",
        "apiVersion": 1
      }
    ]
  },
  "entryPoints": [
    {
      "type": "panel",
      "id": "panel1",
      "main": "index.html",
      "permissions": {
        "sandbox": [
          "allow-popups",
          "allow-popups-to-escape-sandbox"
        ],
        "oauth": []
      }
    }
  ]
}
